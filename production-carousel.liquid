<section class="product-section product-slider">
    <div class="product-carousel">
        <div class="carousel-header">
            <h2 class="product-heading">{{ section.settings.heading }}</h2>
            <a href="{{section.settings.primary_link}}" class="btn">{{ section.settings.primary_text }}</a>
        </div>
        <div class="wrapper">
            <div class="carousel">
                {% for block in section.blocks %}
                {% assign product = block.settings.product %}
                <div class="product-card">
                    <div class="wishlist-icon">
                        <img src="{{ block.settings.wishlist_icon | default: product.metafields.custom.wishlist_icon | image_url }}" alt="{{ block.settings.title | default: product.title }}" width="100%"
                            height="100%">
                    </div>
                    <img src="{{ block.settings.featured_image | default: product.featured_image | image_url }}" alt="{{ block.settings.title | default: product.title }}" width="100%"
                        height="100%">
                    <div class="title-vendor">
                        <h3>{{ block.settings.title | default: product.title }}</h3>
                        <p>{{ block.settings.vendor | default: product.vendor }}</p>
                    </div>
                    <h3>{{ block.settings.price | default: product.price | money }}</h3>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
{% schema  %} 
    {
        "name": "product carousel",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "Heading"
            },
            {
                "type": "text",
                "id": "primary_text",
                "label": "Primary Text"
            },
            {
                "type": "url",
                "id": "primary_link",
                "label": "Primary Link"
            }
        ],
        "blocks": [
            {
                "type": "product",
                "name": "Product",
                "settings": [
                    {
                        "type": "product",
                        "id": "product",
                        "label": "Product"
                    },
                    {
                        "type": "image_picker",
                        "id": "wishlist_icon",
                        "label": "Wishlist Icon"
                    },
                    {
                        "type": "image_picker",
                        "id": "featured_image",
                        "label": "Featured Image"
                    },
                    {
                        "type": "text",
                        "id": "title",
                        "label": "Title"
                    },
                    {
                        "type": "text",
                        "id": "vendor",
                        "label": "Vendor"
                    },
                    {
                        "type": "text",
                        "id": "price",
                        "label": "Price"
                    }
                ]
            }
        ],
        "presets":[{
            "name" :"product carousel",
            "category": "product section"
        }]
    }
{% endschema %}

<style>
    .product-section h2 {
        font-size: 52px;
        line-height: 62px;
        font-weight: 400;
        color: #000;
        font-style: normal;
        letter-spacing: -1%;
    }

    .product-section .product-card p {
        font-size: 14px;
        line-height: 25px;
        font-weight: 400;
        color: #000;
    }

    .product-section .product-card .title-vendor h3 {
        font-size: 16px;
        line-height: 24px;
        font-weight: 600;
        color: #000;
        font-style: normal;
    }

    .product-section .product-card h3 {
        font-size: 44px;
        line-height: 54px;
        font-weight: 400;
        color: #000;
        letter-spacing: -1%;
        font-style: normal;
    }

    .carousel-header .btn {
        font-size: 16px;
        line-height: 26px;
        background: transparent;
        padding: 12px 25px;
        border-radius: 6px;
        color: #fff;
        text-decoration: none;
        font-weight: 500;
        border: 1px solid rgba(0, 0, 0, 0.15);
    }
</style>