<footer>
  <section class="primary_footer">
    <div class="wrapper">
      <div class="container">
        <div class="row">
          <div class="col left-col">
            <h1>{{ section.settings.heading }}</h1>
            <p>{{ section.settings.description }}</p>
            
            <div class="btn-cont">
              <a href="{{ section.settings.primary_link }}" class="btn1">{{ section.settings.primary_text }}</a>
              <a href="{{ section.settings.secondary_link }}" class="btn2">{{ section.settings.secondary_text }}</a>
            </div>
          </div>
          <div class="col right-col">
            <img
              src="{{ section.settings.footer1_img | image_url }}"
              alt="My image's alt text"
              width="100%"
              height="100%"
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "heading",
      "default": "Welcome"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Connect with our team to review product options, align specifications, or plan support for an upcoming project. We’ll respond with next steps based on your scope and timeline."
    },
    {
      "type": "image_picker",
      "id": "footer1_img",
      "label": "Right column image"
    },
    {
      "type": "text",
      "id": "primary_text",
      "label": "Primary button text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link",
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "Specification Support"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link",
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "category": "Footer"
    }
  ]
}
{% endschema %}
    