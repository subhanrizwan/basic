<div class="brand-philosophy-section">
  <div class="container">
    <div class="row">
      <div class="col left-col">
        <h4>{{ section.settings.sub_heading }}</h4>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description1 }}</p>
        <p>{{ section.settings.description1 }}</p>
      </div>
      <div class="col right-col">
        <p>{{ section.settings.description3 }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "custom brand philosophy",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Brand Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Outdoor Craft & Style Heading",
      "default": "Outdoor Craft & Style"
    },
    {
      "type": "textarea",
      "id": "description1",
      "label": "Description 1",
      "default": "OCS operates at the intersection."
    },
    {
      "type": "textarea",
      "id": "description2",
      "label": "Description 2",
      "default": "OCS operates at the intersection."
    },
    {
      "type": "textarea",
      "id": "description3",
      "label": "Description 3",
      "default": "OCS operates at the intersection."
    }
  ],
  "presets": [
    {
      "name": "Custom About Sections",
      "category": "Brand Philosophy"
    }
  ]
}
{% endschema %}
