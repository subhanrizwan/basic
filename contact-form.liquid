<section class="contact-section">
  <div class="contact-banner">
    <div class="container">
      <div class="row contact-row">

        <!-- LEFT COLUMN -->
        <div class="col col-left">

          {% if section.settings.subheading %}
            <h4 class="contact-subheading">{{ section.settings.subheading }}</h4>
          {% endif %}

          {% if section.settings.heading %}
            <h2 class="contact-heading">{{ section.settings.heading }}</h2>
          {% endif %}

          <ul class="icon-list">
            {{ section.settings.icon_text }}
          </ul>

        </div>

        <!-- RIGHT COLUMN -->
        <div class="col col-right">

          <form method="post" action="/contact#contact_form" id="contact_form" class="contact-form">

            <div class="form-split">
              <div class="form-group">
                <label for="fname">First name</label>
                <input type="text" id="fname" name="contact[first_name]" placeholder="First name">
              </div>

              <div class="form-group">
                <label for="lname">Last name</label>
                <input type="text" id="lname" name="contact[last_name]" placeholder="Last name">
              </div>
            </div>

            <div class="form-split">
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="contact[email]" placeholder="Email">
              </div>

              <div class="form-group">
                <label for="phone">Phone number</label>
                <input type="text" id="phone" name="contact[phone]" placeholder="Phone number">
              </div>
            </div>

            <!-- DROPDOWN -->
            <div class="form-group">
              <label for="topic">Choose a topic</label>
              {% assign topics = section.settings.topic_options | split: ',' %}
              <select id="topic" name="contact[topic]">
                <option value="">Select one...</option>
                {% for t in topics %}
                  <option value="{{ t | strip }}">{{ t | strip }}</option>
                {% endfor %}
              </select>
            </div>

            <!-- MESSAGE -->
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="contact[body]" placeholder="Type your message..." rows="6"></textarea>
            </div>

            <!-- CHECKBOX -->
            <div class="checkbox-wrap">
              <input type="checkbox" id="terms">
              <label for="terms">I accept the <a href="#">Terms</a></label>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="contact-btn">{{ section.settings.button_text }}</button>

          </form>

        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Section Advanced",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (H4)",
      "default": "GET IN TOUCH"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H2)",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "topic_options",
      "label": "Dropdown Topic Options (comma separated)",
      "default": "General Inquiry, Support, Partnership, Custom Order"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Submit Button Text",
      "default": "Submit"
    },
    {
    "type": "richtext",
    "id": "icon_text",
    "label": "Icon List"
    }
  ],
  "presets": [
    { 
       "name": "Contact Form",
        "category": "Custom Contact Section"
     }
  ]
}
{% endschema %}
