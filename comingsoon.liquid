<header>
    <div class="announcement-bar">
        <p>{{ section.settings.announcement_text }}</p>
    </div>
</header>

<section class="comingsoon-section">
    <div class="comingsoon-content">
        <div class="logo-container">
            <img src="{{ section.settings.comingsoon_logo | image_url }}" alt="Coming Soon Logo" width="300px" height="300px">
        </div>
        <h1 class="comingsoon-title">{{ section.settings.heading }}</h1>
        <h2 class="comingsoon-subtitle">{{ section.settings.subheading }}</h2>
    </div>
</section>

{% schema %}
{
  "name": "Coming Soon",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Bar Text",
      "default": "Welcome to our store"
    },
    {
      "type": "image_picker",
      "id": "comingsoon_logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Outdoor Craft & Style"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Online Shop Coming Soon"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Coming Soon"
    }
  ]
}
{% endschema %}

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* Announcement Bar Styles */
  .announcement-bar {
    background-color: #ffffff;
    padding: 15px 0;
    text-align: center;
    border-bottom: 1px solid #e5e5e5;
    width: 100%;
  }

.announcement-bar p {
    font-size: 1.2rem;
    line-height: 24px;
    color: #333333;
    font-family: inter, sans-serif !important;
    font-weight: 500;
}


.comingsoon-section {
    width: 100%;
    min-height: 100vh;
    background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('{{ section.settings.background_image | image_url: width: 1920 }}');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 15px;
}    

  .comingsoon-content {
    text-align: center;
    z-index: 2;
    max-width: 90%;
    width: 100%;
    padding: 20px;
  }

  .logo-container {
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .comingsoon-logo {
    max-width: 150px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

.comingsoon-title {
    font-size: clamp(2.25rem, 8vw, 4rem);
    font-style: normal;
    color: #ffffff;
    font-weight: 700;
    letter-spacing: -1px;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    line-height: 1.2;
}
.comingsoon-subtitle
 {
    font-size: 48px;
    color: #fff;
    font-weight: 600;
    letter-spacing: 1px;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    line-height: 55px;
    font-style: normal;
}

  /* Responsive Design */
  @media (max-width: 768px) {
    .comingsoon-section {
      background-attachment: scroll;
    }

    .logo-container {
      margin-bottom: 30px;
    }

    .comingsoon-logo {
      max-width: 120px;
    }

    .comingsoon-title {
      margin-bottom: 10px;
    }

    .announcement-bar p {
      font-size: 0.7rem;
    }
  }

  @media (max-width: 480px) {
    .comingsoon-content {
      max-width: 95%;
      padding: 15px;
    }

    .logo-container {
      margin-bottom: 25px;
    }

    .comingsoon-logo {
      max-width: 100px;
    }

    .comingsoon-title {
      margin-bottom: 8px;
    }

    .announcement-bar p {
      font-size: 0.65rem;
      padding: 12px 0;
    }
  }
</style>