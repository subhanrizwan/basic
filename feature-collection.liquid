<section class="featured-collections" style="background-image:url('{{ block.settings.bg_image | image_url }}');">
  <div class="page-width">

    {% if section.settings.subheading != blank %}
      <h4 class="fc-subheading">
        {{ section.settings.subheading }}
      </h4>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="fc-heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="fc-grid">
      {% for block in section.blocks %}
        {% assign collection = block.settings.collection %}

        <a href="{{ collection.url }}" class="fc-card">

          {% if collection.image %}
            <img
              src="{{ collection.image | image_url }}"
              alt="{{ collection.title }}"
              loading="lazy" width="100%" height="100%"
            >
          {% endif %}

          <h5 class="fc-title">
            {{ collection.title }}
          </h5>

        </a>
      {% endfor %}
    </div>

  </div>
</section>


<style>

.featured-collections{
  padding:80px 0;
  background:#f4f2ee;
  text-align:center;

  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.fc-subheading{
  font-family:'Open Sans', sans-serif;
  font-size:16px;
  font-weight:600;
  margin-bottom:10px;
  letter-spacing:.08em;
}

.fc-heading{
  font-family:'Open Sans', sans-serif;
  font-size:52px;
  font-weight:400;
  letter-spacing:-0.01em;
  margin-bottom:50px;
}

.fc-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:25px;
}

.fc-card{
  text-decoration:none;
  color:#000;
}

.fc-card img{
  width:100%;
  height:420px;
  object-fit:cover;
  border-radius:10px;
  transition:transform .4s ease;
}

.fc-card:hover img{
  transform:scale(1.05);
}

.fc-title{
  margin-top:12px;
  font-family:'Open Sans', sans-serif;
  font-size:18px;
  font-weight:500;
}

@media(max-width:990px){

.fc-grid{
  grid-template-columns:repeat(2,1fr);
}

.fc-heading{
  font-size:40px;
}

}

@media(max-width:600px){

.fc-grid{
  grid-template-columns:1fr;
}

.fc-heading{
  font-size:32px;
}

}

</style>


{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
        "type": "image_picker",
        "id": "bg_image"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "SHOP BY STYLE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        {"type":"collection"},
        {"type":"collection"},
        {"type":"collection"},
        {"type":"collection"}
      ]
    }
  ]
}
{% endschema %}